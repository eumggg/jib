## Copy this file to .env and fill in real values.
## DO NOT commit .env to version control.

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL + PostGIS (matches docker-compose.yml defaults)
DATABASE_URL=postgres://jib:jib_dev@localhost:5432/jib

# Firebase Admin SDK — paste the entire contents of your service account JSON here
# (single-line JSON string, never commit the actual value)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Alternatively set GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json for ADC
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"REPLACE_ME","private_key_id":"REPLACE_ME","private_key":"REPLACE_ME","client_email":"REPLACE_ME","client_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_32_CHARS_MIN
