{
  "name": "jib-backend",
  "version": "0.1.0",
  "description": "JIB EV charging station finder — REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "firebase-admin": "^12.2.0",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.1.0",
    "uuid": "^10.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.9",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
